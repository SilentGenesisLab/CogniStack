generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  TEAM
}

enum Quadrant {
  URGENT_IMPORTANT
  NOT_URGENT_IMPORTANT
  URGENT_NOT_IMPORTANT
  NOT_URGENT_NOT_IMPORTANT
}

enum Mood {
  GREAT
  GOOD
  NEUTRAL
  BAD
  TERRIBLE
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  phone        String?       @unique
  name         String?
  passwordHash String?
  avatar       String?
  plan         Plan          @default(FREE)
  streak       Int           @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  decks        Deck[]
  tasks        Task[]
  taskLists    TaskList[]
  trainingLogs TrainingLog[]
  moodLogs     MoodLog[]

  @@map("users")
}

model Deck {
  id          String   @id @default(cuid())
  title       String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([userId])
  @@map("decks")
}

model Card {
  id         String    @id @default(cuid())
  front      String
  back       String
  deckId     String
  stability  Float     @default(0)
  difficulty Float     @default(0)
  dueAt      DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deck       Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviewLogs ReviewLog[]

  @@index([deckId])
  @@index([dueAt])
  @@map("cards")
}

model ReviewLog {
  id        String   @id @default(cuid())
  cardId    String
  rating    Int
  timeSpent Int      // milliseconds
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("review_logs")
}

model TaskList {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3B82F6")
  sortOrder Int      @default(0)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
  @@map("task_lists")
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  userId         String
  listId         String?
  parentId       String?
  quadrant       Quadrant  @default(NOT_URGENT_NOT_IMPORTANT)
  priority       Int       @default(0)
  dueAt          DateTime?
  completedAt    DateTime?
  pomodoroCount  Int       @default(0)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list     TaskList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  parent   Task?     @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks Task[]    @relation("TaskSubtasks")

  @@index([userId])
  @@index([listId])
  @@index([parentId])
  @@map("tasks")
}

model TrainingLog {
  id        String   @id @default(cuid())
  userId    String
  dimension String   // e.g. "attention", "memory", "logic"
  score     Float
  duration  Int      // seconds
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("training_logs")
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  mood      Mood
  note      String?
  biases    String[] // cognitive biases detected
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mood_logs")
}

model VerificationCode {
  id        String   @id @default(cuid())
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([email, code])
  @@map("verification_codes")
}
